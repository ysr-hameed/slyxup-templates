    "accentColor": { "type": "color", "label": "Accent Color", "default": "#58a6ff" },
    "textColor": { "type": "color", "label": "Text Color", "default": "#ffffff" }
  },
  "defaultProps": { "headline": "AI Model Achieves Human-Level Reasoning", "summary": "New model surpasses benchmarks", "source": "TechCrunch", "bgColor": "#0d1117", "accentColor": "#58a6ff", "textColor": "#ffffff" },
  "tags": ["tech", "news", "coding", "ai", "animated"],
  "premium": false,
  "entry": "./dist/index.js"
